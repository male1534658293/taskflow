{
  "name": "taskflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "vite build && electron .",
    "electron:build": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.378.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.taskflow.app",
    "productName": "TaskFlow",
    "copyright": "Copyright © 2026",
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/icon.icns",
      "!**/*.map",
      "!**/*.md",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/node_modules/.cache/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "male1534658293",
        "repo": "taskflow"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "TaskFlow ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
